# Copy to .env for local development. Never commit .env.
#
# Local Postgres runs in docker compose on port 5433 (5432 is often taken).
# These credentials are for local development only; do not reuse in production.

POSTGRES_USER=tename
POSTGRES_PASSWORD=tename
POSTGRES_DB=tename_dev
POSTGRES_PORT=5433

# SQLAlchemy / Alembic connection string. Uses psycopg v3.
TENAME_DATABASE_URL=postgresql+psycopg://tename:tename@localhost:5433/tename_dev

# Integration-test connection string. `scripts/dev-setup.sh` creates this
# database on startup. Tests that require Postgres are skipped when unset.
TENAME_TEST_DATABASE_URL=postgresql+psycopg://tename:tename@localhost:5433/tename_test
